const AWS = require("aws-sdk");
const db = new AWS.DynamoDB.DocumentClient();

exports.handler = async (event) => {
  const { name, posts } = JSON.parse(event.body);

  await db.put({
    TableName: "elections",
    Item: {
      id: Date.now().toString(),
      name,
      posts: Math.min(posts, 7),
      status: "SCHEDULED",
    },
  }).promise();

  return { statusCode: 200, body: "Election created" };
};
